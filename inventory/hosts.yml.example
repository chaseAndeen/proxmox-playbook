proxmox:
  hosts:
    pve-node-01:
      ansible_host: 192.168.x.x
      ansible_user: "{{ ansible_service_user }}"
      ansible_port: "{{ proxmox_ssh_port }}"
      ansible_become: true
      pve_nvme_provision: true
      pve_zfs_device: "/dev/nvme1n1"
      pve_zfs_pool: "your-pool-name"
      pve_nvme_storage_id: "your-pool-name"
      pve_disable_local_lvm: true
      pbs_server: "192.168.x.x"
      pbs_storage_id: "pbs-main"
      pbs_datastore_name: "main"
      pbs_backup_user: "backup-user@pbs"
      pbs_backup_schedule: "2:00"
      pbs_backup_mode: "snapshot"

pbs:
  hosts:
    pbs-01:
      ansible_host: 192.168.x.x
      ansible_user: "{{ ansible_service_user }}"
      ansible_port: "{{ proxmox_ssh_port }}"
      ansible_become: true
      pbs_datastore_name: "main"
      pbs_datastore_path: "/mnt/backups"
      pbs_nfs_server: "nas.example.com"
      pbs_nfs_export: "/mnt/pool/dataset"
      pbs_nfs_opts: "defaults,nofail,_netdev,nfsvers=4"
      pbs_nfs_user: "pbs_user"
      pbs_nfs_uid: 2000
      pbs_nfs_group: "proxmox_group"
      pbs_nfs_gid: 2000
      pbs_keep_daily: 7
      pbs_keep_weekly: 7
      pbs_prune_schedule: "daily"
      pbs_gc_schedule: "weekly"
      pbs_backup_user: "backup-user@pbs"
      pbs_backup_user_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/pbs/backup_user_password', profile=aws_profile, region=aws_region) }}"
