---
profile: production

exclude_paths:
  - .git/
  - inventory/group_vars/all.yml
  - inventory/hosts.yml

warn_list:
  - experimental

skip_list:
  - no-changed-when
  - no-handler
  - command-instead-of-module
  - command-instead-of-shell
  - risky-shell-pipe
  - var-naming[no-role-prefix]
  - yaml[new-line-at-end-of-file]
  - yaml[empty-lines]
